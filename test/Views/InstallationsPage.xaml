<Page
  x:Class="test.Views.InstallationsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
>
  <Grid Margin="{StaticResource NavigationViewPageContentMargin}" RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <!--  Title  -->
    <Grid Grid.Row="0" Margin="0,24,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock
        x:Uid="InstallationsPage_Header"
        Grid.Column="0"
        Style="{ThemeResource TitleTextBlockStyle}"
      />
    </Grid>
    <!--  Progress (appears below title)  -->
    <StackPanel x:Name="ProgressPanel" Grid.Row="1" Spacing="6" Visibility="Collapsed">
      <TextBlock
        x:Name="ProgressStatusText"
        x:Uid="InstallationsPage_Installing"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
      />
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ProgressBar x:Name="InstallProgressBar" Grid.Column="0" Maximum="100" Value="0" />
        <TextBlock
          x:Name="ProgressPercentText"
          Grid.Column="1"
          Margin="12,0,0,0"
          VerticalAlignment="Center"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Style="{ThemeResource CaptionTextBlockStyle}"
        />
      </Grid>
    </StackPanel>
    <!--  Path row: TextBox (read-only) with inline Clear (X), and Install (disabled if no path)  -->
    <Grid Grid.Row="2" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <!--  TextBox with refined right padding to avoid overlap with ClearButton  -->
      <TextBox
        x:Name="SelectedFileText"
        x:Uid="InstallationsPage_FileText"
        Grid.Column="0"
        MinHeight="40"
        Margin="0,0,8,0"
        Padding="10,6,42,6"
        VerticalAlignment="Center"
        VerticalContentAlignment="Center"
        IsReadOnly="True"
      />
      <!--  Clear button overlaid inside TextBox area  -->
      <Button
        x:Name="ClearButton"
        Grid.Column="0"
        Width="40"
        Height="40"
        Margin="4,0"
        Padding="0"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Background="Transparent"
        BorderThickness="0"
        Canvas.ZIndex="1"
        Click="ClearButton_Click"
        ToolTipService.ToolTip="Clear"
        Visibility="Collapsed"
      >
        <FontIcon Glyph="" />
      </Button>
      <!--  Install button (greyed out when disabled)  -->
      <Button
        x:Name="InstallButton"
        x:Uid="InstallationsPage_InstallBtn"
        Grid.Column="1"
        Height="40"
        MinWidth="100"
        Click="InstallButton_Click"
        IsEnabled="False"
        Style="{ThemeResource AccentButtonStyle}"
      />
    </Grid>
    <!--  Drag and drop panel button: fills remaining space to bottom, also opens file picker on click  -->
    <Button
      x:Name="DropZoneButton"
      Grid.Row="3"
      Margin="0,0,0,24"
      Padding="24"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      AllowDrop="True"
      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
      BorderThickness="1"
      Click="DropZoneButton_Click"
      CornerRadius="8"
      DragOver="DropZone_DragOver"
      Drop="DropZone_Drop"
    >
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <FontIcon
          x:Name="DropZoneIcon"
          FontFamily="{StaticResource SymbolThemeFontFamily}"
          FontSize="36"
          Glyph=""
        />
        <TextBlock
          x:Name="DropZoneText"
          x:Uid="InstallationsPage_DropZone"
          HorizontalAlignment="Center"
          FontSize="18"
        />
      </StackPanel>
    </Button>
  </Grid>
</Page>
